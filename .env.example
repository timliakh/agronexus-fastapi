# Скопируйте в .env и заполните обязательные переменные перед запуском.
#
# Docker: достаточно задать SECRET_KEY (DATABASE_URL переопределяется в docker-compose.yml).
# Локально без Docker: также задайте DATABASE_URL.
#
# Примеры:
#   SECRET_KEY=my-long-random-secret-key
#   DATABASE_URL=postgresql://agrostore:agrostore@localhost:5432/agrostore

# Обязательно — ключ HMAC для admin-токенов
SECRET_KEY=

# Пароль админки (если строка отсутствует, по умолчанию admin123)
# ADMIN_PASSWORD=

# Обязательно для локального uvicorn (в Docker не используется)
DATABASE_URL=

# Учётные данные контейнера postgres
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
